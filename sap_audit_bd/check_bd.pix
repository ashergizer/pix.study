        <PropertyValues>
          <PropertyValue z:Id="i106">
            <PropertyName>Value</PropertyName>
            <_dataType>Expression</_dataType>
            <_expression>"&lt;!DOCTYPE html&gt;&lt;html&gt;&lt;head&gt;&lt;meta charset='utf-8'&gt;" +
"&lt;style&gt;" +
"body{font-family:Calibri,Arial,sans-serif;font-size:13px;color:#222;margin:30px}" +
"h2{color:#1F4E79}" +
"h3{color:#1F4E79;border-bottom:2px solid #1F4E79;padding-bottom:4px;margin-top:24px}" +
"table{border-collapse:collapse;width:100%;margin-top:8px}" +
"th{background:#1F4E79;color:#fff;padding:7px 10px;text-align:left}" +
"td{padding:6px 10px;border-bottom:1px solid #ddd}" +
".kpi{display:flex;gap:16px;margin:16px 0}" +
".box{padding:12px 20px;border-radius:8px;text-align:center;min-width:80px;font-weight:bold}" +
".ok{background:#d6f0d6;color:#2d6a2d}" +
".diff{background:#fde8e8;color:#a00}" +
".stub{background:#fff3cd;color:#856404}" +
".foot{margin-top:30px;color:#888;font-size:11px}" +
"&lt;/style&gt;&lt;/head&gt;&lt;body&gt;" +

"&lt;h2&gt;🔍 Аудит дат рождения (GBDAT) — Инфотип 0002&lt;/h2&gt;" +
"&lt;p&gt;Дата формирования: &lt;b&gt;" + DateTime.Now.ToString("dd.MM.yyyy HH:mm") + "&lt;/b&gt;" +
" &amp;nbsp;|&amp;nbsp; Всего проверено: &lt;b&gt;" + (iOK + iDiff + iStub).ToString() + "&lt;/b&gt;&lt;/p&gt;" +

"&lt;div class='kpi'&gt;" +
"&lt;div class='box ok'&gt;✅ Совпадений&lt;br&gt;" + iOK.ToString() + "&lt;/div&gt;" +
"&lt;div class='box diff'&gt;❌ Расхождений&lt;br&gt;" + iDiff.ToString() + "&lt;/div&gt;" +
"&lt;div class='box stub'&gt;⚠️ Заглушек&lt;br&gt;" + iStub.ToString() + "&lt;/div&gt;" +
"&lt;/div&gt;" +

"&lt;h3&gt;❌ Расхождения (" + iDiff.ToString() + ")&lt;/h3&gt;" +
"&lt;table&gt;&lt;tr&gt;" +
"&lt;th&gt;Таб. №&lt;/th&gt;&lt;th&gt;ФИО&lt;/th&gt;" +
"&lt;th&gt;Дата в Excel&lt;/th&gt;&lt;th&gt;Дата в SAP&lt;/th&gt;&lt;th&gt;Комментарий&lt;/th&gt;" +
"&lt;/tr&gt;" + sRowsDiff + "&lt;/table&gt;" +

"&lt;h3&gt;⚠️ Заглушки в SAP (" + iStub.ToString() + ")&lt;/h3&gt;" +
"&lt;table&gt;&lt;tr&gt;" +
"&lt;th&gt;Таб. №&lt;/th&gt;&lt;th&gt;ФИО&lt;/th&gt;" +
"&lt;th&gt;Дата в Excel&lt;/th&gt;&lt;th&gt;Дата в SAP&lt;/th&gt;&lt;th&gt;Комментарий&lt;/th&gt;" +
"&lt;/tr&gt;" + sRowsStub + "&lt;/table&gt;" +

"&lt;h3&gt;✅ Совпадения (" + iOK.ToString() + ")&lt;/h3&gt;" +
"&lt;table&gt;&lt;tr&gt;" +
"&lt;th&gt;Таб. №&lt;/th&gt;&lt;th&gt;ФИО&lt;/th&gt;" +
"&lt;th&gt;Дата в Excel&lt;/th&gt;&lt;th&gt;Дата в SAP&lt;/th&gt;&lt;th&gt;Статус&lt;/th&gt;" +
"&lt;/tr&gt;" + sRowsOK + "&lt;/table&gt;" +

"&lt;div class='foot'&gt;Сформировано автоматически · PIX Robot · SAP HCM PA20 / IT0002&lt;/div&gt;" +
"&lt;/body&gt;&lt;/html&gt;"</_expression>
            <_screenShotBase64 i:nil="true" />
            <_value i:nil="true" />
            <_xpathSettings xmlns:d7p1="http://schemas.datacontract.org/2004/07/BR.XPath" i:nil="true" />
          </PropertyValue>
